# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ─────────────────────────────────────────────────────────────────────────────
# Next.js build output
# ─────────────────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─────────────────────────────────────────────────────────────────────────────
# Environment files — NEVER commit these
# .env.example is the only env file that should be committed
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ─────────────────────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ─────────────────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ─────────────────────────────────────────────────────────────────────────────
# User-generated content — never commit uploads or AI outputs
# ─────────────────────────────────────────────────────────────────────────────
/uploads
/exports
/tmp
/public/uploads
/public/outputs

# ─────────────────────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# IDE / editor files
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Recommended to keep for team consistency (uncomment if desired):
# .editorconfig

# ─────────────────────────────────────────────────────────────────────────────
# Certificates / secrets
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12

# ─────────────────────────────────────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────────────────────────────────────
.vercel
.netlify
