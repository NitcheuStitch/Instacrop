# ─────────────────────────────────────────────────────────────────────────────
# InstaCrop — Environment Variables Template
#
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file containing real keys.
# This file (.env.example) is safe to commit — it contains no secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Get these from: https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — SERVER-SIDE ONLY. Never expose this to the browser.
# Used for storage operations and admin queries in API routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini
# Get your key from: https://aistudio.google.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Gemini API key — SERVER-SIDE ONLY. Used in API routes for image generation.
GEMINI_API_KEY=your_gemini_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of the app (used for auth redirects)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Max upload file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Max variants allowed per generation job (default: 4)
MAX_VARIANTS=4
